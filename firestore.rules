rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helper functions --------
    function getUserRole() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) ? get(userDoc).data.role : null;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }

    function isTutor() {
      return request.auth != null && getUserRole() == 'tutor';
    }

    function isStudent() {
      return request.auth != null && getUserRole() == 'student';
    }

    function isTestCreator() {
      return request.auth != null && getUserRole() == 'test_creator';
    }

    function isTutorLike() {
      return request.auth != null && (isTutor() || isTestCreator());
    }

    function classPath(classId) {
      return /databases/$(database)/documents/classes/$(classId);
    }

    function classExists(classId) {
      return classId is string && exists(classPath(classId));
    }

    function isClassTutor(classId) {
      return request.auth != null && classExists(classId) && (
        get(classPath(classId)).data.tutorId == request.auth.uid ||
        get(classPath(classId)).data.instructorId == request.auth.uid
      );
    }

    function isClassMember(classId) {
      return request.auth != null && classExists(classId) && (
        isClassTutor(classId) ||
        get(classPath(classId)).data.get('members', []).hasAny([request.auth.uid])
      );
    }

    function canAccessClassContent(classId) {
      return request.auth != null && (isAdmin() || isClassMember(classId));
    }

    function assignmentPath(assignmentId) {
      return /databases/$(database)/documents/assignments/$(assignmentId);
    }

    function assignmentExists(assignmentId) {
      return assignmentId is string && exists(assignmentPath(assignmentId));
    }

    function canTutorAccessAssignment(assignmentId) {
      return request.auth != null && assignmentExists(assignmentId) && (
        isAdmin() || isClassTutor(get(assignmentPath(assignmentId)).data.classId)
      );
    }

    function canStudentSubmitAssignment(assignmentId) {
      return request.auth != null && assignmentExists(assignmentId) && (
        isStudent() &&
        isClassMember(get(assignmentPath(assignmentId)).data.classId)
      );
    }

    function unitPath(unitId) {
      return /databases/$(database)/documents/units/$(unitId);
    }

    function unitExists(unitId) {
      return unitId is string && exists(unitPath(unitId));
    }

    function canAccessUnit(unitId) {
      return request.auth != null && unitExists(unitId) && (
        isAdmin() || canAccessClassContent(get(unitPath(unitId)).data.classId)
      );
    }

    function canManageUnit(unitId) {
      return request.auth != null && unitExists(unitId) && (
        isAdmin() || isClassTutor(get(unitPath(unitId)).data.classId)
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null && (
        isAdmin() || 
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
      );
      allow delete: if isAdmin();
    }

    // User notifications subcollection
    match /users/{userId}/notifications/{notificationId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && (request.auth.uid == userId || isTutor() || isAdmin() || isTestCreator());
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/deviceTokens/{tokenId} {
      allow read, create, update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /chat_rooms/{chatRoomId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        isTestCreator() ||
        (resource.data.classId is string && canAccessClassContent(resource.data.classId))
      );

      allow create: if request.auth != null && (
        isAdmin() ||
        (
          request.resource.data.classId is string &&
          canAccessClassContent(request.resource.data.classId)
        ) ||
        isTestCreator()
      );

      allow update: if request.auth != null && (
        isAdmin() ||
        isTestCreator() ||
        (
          resource.data.classId is string &&
          isClassTutor(resource.data.classId)
        ) ||
        (
          resource.data.classId is string &&
          canAccessClassContent(resource.data.classId) &&
          request.resource.data.classId == resource.data.classId &&
          request.resource.data.className == resource.data.className &&
          request.resource.data.tutorId == resource.data.tutorId &&
          request.resource.data.tutorName == resource.data.tutorName &&
          request.resource.data.studentIds == resource.data.studentIds &&
          request.resource.data.permissions == resource.data.permissions &&
          request.resource.data.isActive == resource.data.isActive
        )
      );

      allow delete: if request.auth != null && (
        isAdmin() ||
        (
          resource.data.classId is string &&
          isClassTutor(resource.data.classId)
        ) ||
        isTestCreator()
      );
    }

    match /chat_rooms/{chatRoomId}/messages/{messageId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        isTestCreator() ||
        (
          get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.classId is string &&
          canAccessClassContent(get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.classId)
        )
      );

      allow create, update, delete: if request.auth != null && (
        isAdmin() ||
        isTestCreator() ||
        (
          get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.classId is string &&
          canAccessClassContent(get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.classId)
        )
      );
    }
    
    // Classes collection
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.resource.data.tutorId == request.auth.uid || isAdmin());
      
      allow update: if request.auth != null && (
        isAdmin() ||
        resource.data.tutorId == request.auth.uid ||
        resource.data.instructorId == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
         (
           (request.resource.data.members.hasAll(resource.data.get('members', [])) &&
            request.resource.data.members.hasAny([request.auth.uid]) &&
            !resource.data.get('members', []).hasAny([request.auth.uid]))
           ||
           (resource.data.get('members', []).hasAll(request.resource.data.members) &&
            resource.data.get('members', []).hasAny([request.auth.uid]) &&
            !request.resource.data.members.hasAny([request.auth.uid]))
         )
        )
      );
      
      allow delete: if request.auth != null && (resource.data.tutorId == request.auth.uid || resource.data.instructorId == request.auth.uid || isAdmin());
    }
    
    // Assignments collection
    match /assignments/{assignmentId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        (resource.data.classId is string && canAccessClassContent(resource.data.classId)) ||
        resource.data.createdBy == request.auth.uid
      );
      allow create: if request.auth != null && (
        isAdmin() ||
        (
          isTutorLike() &&
          request.resource.data.classId is string &&
          isClassTutor(request.resource.data.classId)
        )
      );
      allow update, delete: if request.auth != null && (
        isAdmin() ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.instructorId == request.auth.uid ||
        resource.data.tutorId == request.auth.uid ||
        (resource.data.classId is string && isClassTutor(resource.data.classId))
      );
    }

    // Assignment Submissions
    match /assignment_submissions/{submissionId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        resource.data.studentId == request.auth.uid ||
        canTutorAccessAssignment(resource.data.assignmentId)
      );
      allow create: if request.auth != null && (
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.assignmentId is string &&
        canStudentSubmitAssignment(request.resource.data.assignmentId)
      );
      allow update: if request.auth != null && (
        isAdmin() ||
        canTutorAccessAssignment(resource.data.assignmentId) ||
        (
          resource.data.studentId == request.auth.uid &&
          request.resource.data.studentId == resource.data.studentId &&
          request.resource.data.assignmentId == resource.data.assignmentId
        )
      );
      allow delete: if request.auth != null && (
        isAdmin() ||
        resource.data.studentId == request.auth.uid
      );
    }

    // Tests collection
    match /tests/{testId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isTutor() || isAdmin() || isTestCreator());
      allow update, delete: if request.auth != null && (
        resource.data.createdBy == request.auth.uid || 
        resource.data.instructorId == request.auth.uid || 
        resource.data.tutorId == request.auth.uid || 
        isAdmin()
      );
    }

    // Test Submissions collection
    match /test_submissions/{submissionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
    }
    
    // Invites collection
    match /invites/{inviteId} {
      allow create: if request.auth != null && (isTutor() || isAdmin() || isTestCreator());
      allow read, update: if request.auth != null && (
        resource.data.invitedUserEmail == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email ||
        resource.data.invitedUserEmail == request.auth.token.email ||
        resource.data.invitedByUserId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if request.auth != null && (
        resource.data.invitedByUserId == request.auth.uid || 
        isAdmin()
      );
    }

    // Units collection
    match /units/{unitId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        (resource.data.classId is string && canAccessClassContent(resource.data.classId))
      );
      allow create: if request.auth != null && (
        isAdmin() ||
        (
          isTutorLike() &&
          request.resource.data.classId is string &&
          isClassTutor(request.resource.data.classId)
        )
      );
      allow update, delete: if request.auth != null && (
        isAdmin() ||
        resource.data.tutorId == request.auth.uid ||
        resource.data.instructorId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        (resource.data.classId is string && isClassTutor(resource.data.classId))
      );
    }

    // Materials collection
    match /materials/{materialId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        (resource.data.unitId is string && canAccessUnit(resource.data.unitId))
      );
      allow create: if request.auth != null && (
        isAdmin() ||
        (
          isTutorLike() &&
          request.resource.data.unitId is string &&
          canManageUnit(request.resource.data.unitId)
        )
      );
      allow update, delete: if request.auth != null && (
        isAdmin() ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.tutorId == request.auth.uid ||
        resource.data.instructorId == request.auth.uid ||
        (resource.data.unitId is string && canManageUnit(resource.data.unitId))
      );
    }

    // Meetings collection
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isAdmin() || isTutor() || isTestCreator());
      // Support all 3 common ID aliases to fix permission errors across cross-platform meetings
      allow update, delete: if request.auth != null && (
        resource.data.createdBy == request.auth.uid || 
        resource.data.instructorId == request.auth.uid || 
        resource.data.tutorId == request.auth.uid || 
        isAdmin()
      );
    }
  }
}
